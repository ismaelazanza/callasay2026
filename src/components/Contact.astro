---
---

<section id="contacto" class="relative py-24 bg-zinc-900/40">
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16">

      <!-- Left: Contact info -->
      <div>
        <div class="inline-flex items-center gap-2 bg-rose-950/40 border border-rose-900/40 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="text-rose-400 text-sm font-semibold uppercase tracking-wider">Contacto</span>
        </div>

        <h2 class="text-4xl sm:text-5xl font-black text-white mb-6" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
          Conéctate <br /><span class="gradient-text">con Nosotros</span>
        </h2>

        <p class="text-zinc-400 text-lg leading-relaxed mb-10">
          Estamos para escucharte. Ya sea para mandar saludos, colaborar, anunciar tu negocio o cotizar un evento —
          nuestro equipo está listo para atenderte.
        </p>

        <!-- Contact cards -->
        <div class="space-y-4">

          <div class="flex items-start gap-4 bg-zinc-900 border border-zinc-800 rounded-2xl p-5">
            <div class="w-12 h-12 rounded-xl bg-rose-950 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </div>
            <div>
              <p class="text-zinc-500 text-xs uppercase tracking-wider mb-1">Estados Unidos</p>
              <p class="text-white font-semibold">1123 N Ridgeway Ave Chicago Il 60651</p>
              <a href="tel:+12152077510" class="text-rose-400 hover:text-rose-300 text-sm transition-colors">+1 773-807-0486</a>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-zinc-900 border border-zinc-800 rounded-2xl p-5">
            <div class="w-12 h-12 rounded-xl bg-rose-950 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </div>
            <div>
              <p class="text-zinc-500 text-xs uppercase tracking-wider mb-1">Ecuador — Callasay</p>
              <p class="text-white font-semibold">Parque Central, Callasay</p>
              <a href="tel:+593991774848" class="text-rose-400 hover:text-rose-300 text-sm transition-colors"></a>
            </div>
          </div>

          <div class="flex items-start gap-4 bg-zinc-900 border border-zinc-800 rounded-2xl p-5">
            <div class="w-12 h-12 rounded-xl bg-rose-950 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-zinc-500 text-xs uppercase tracking-wider mb-1">Email</p>
              <a href="mailto:launicacallasayestereo@gmail.com" class="text-white font-semibold hover:text-rose-400 transition-colors">
                launicacallasayestereo@gmail.com
              </a>
            </div>
          </div>
        </div>

        <!-- Support -->
        <div class="mt-8 bg-gradient-to-r from-amber-950/30 to-zinc-900/30 border border-amber-900/30 rounded-2xl p-6">
          <h4 class="text-amber-400 font-bold mb-3 uppercase tracking-wider text-sm" style="font-family: 'Oswald', sans-serif;">
            Apoya la Radio
          </h4>
          <p class="text-zinc-400 text-sm mb-4">
            Tu apoyo nos permite seguir transmitiendo para toda la comunidad. Dona por PayPal.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://paypal.com"
              target="_blank"
              rel="noopener"
              class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold px-4 py-3 rounded-xl transition-colors flex items-center gap-2"
            >
              Donar por PayPal
            </a>
          </div>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8">
        <h3 class="text-2xl font-black text-white mb-6" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
          Escríbenos
        </h3>

        <!-- Success state -->
        <div id="form-success" class="hidden flex-col items-center justify-center text-center py-12 gap-4">
          <div class="w-16 h-16 rounded-full bg-emerald-600/20 border border-emerald-600/40 flex items-center justify-center mb-2">
            <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h4 class="text-white font-bold text-xl" style="font-family: 'Oswald', sans-serif;">¡Mensaje enviado!</h4>
          <p class="text-zinc-400 text-sm max-w-xs">Gracias por escribirnos. Te responderemos a la brevedad posible.</p>
          <button id="form-reset" class="mt-2 text-rose-400 hover:text-rose-300 text-sm font-semibold transition-colors">
            Enviar otro mensaje
          </button>
        </div>

        <!-- Error state -->
        <div id="form-error" class="hidden mb-4 bg-red-950/40 border border-red-800/50 rounded-xl px-4 py-3 text-red-400 text-sm">
          Hubo un error al enviar. Por favor intenta de nuevo o escríbenos por WhatsApp.
        </div>

        <form class="space-y-5" id="contact-form">
          <!-- Web3Forms access key — enviará a ismaelazanza@gmail.com -->
          <input type="hidden" name="access_key" value="79a8e2d8-f1cc-4ca7-a7ce-bbb63f91fdf5" />
          <input type="hidden" name="subject" value="Nuevo mensaje desde Callasay Stereo" />
          <input type="hidden" name="from_name" value="Callasay Stereo Web" />
          <input type="hidden" name="redirect" value="false" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="text-zinc-400 text-sm font-medium block mb-2" for="name">Nombre <span class="text-rose-500">*</span></label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Tu nombre"
                class="w-full bg-zinc-800 border border-zinc-700 focus:border-rose-600 text-white placeholder-zinc-600 rounded-xl px-4 py-3 text-sm outline-none transition-colors"
              />
            </div>
            <div>
              <label class="text-zinc-400 text-sm font-medium block mb-2" for="email">Email <span class="text-rose-500">*</span></label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="tu@email.com"
                class="w-full bg-zinc-800 border border-zinc-700 focus:border-rose-600 text-white placeholder-zinc-600 rounded-xl px-4 py-3 text-sm outline-none transition-colors"
              />
            </div>
          </div>

          <div>
            <label class="text-zinc-400 text-sm font-medium block mb-2" for="subject-select">Asunto</label>
            <select
              id="subject-select"
              name="asunto"
              class="w-full bg-zinc-800 border border-zinc-700 focus:border-rose-600 text-white rounded-xl px-4 py-3 text-sm outline-none transition-colors"
            >
              <option value="">Selecciona un tema</option>
              <option value="Mandar un saludo">Mandar un saludo</option>
              <option value="Publicidad y patrocinio">Publicidad y patrocinio</option>
              <option value="Cotizar un evento">Cotizar un evento</option>
              <option value="Colaboración artística">Colaboración artística</option>
              <option value="Otro">Otro</option>
            </select>
          </div>

          <div>
            <label class="text-zinc-400 text-sm font-medium block mb-2" for="message">Mensaje <span class="text-rose-500">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="Cuéntanos en qué podemos ayudarte..."
              class="w-full bg-zinc-800 border border-zinc-700 focus:border-rose-600 text-white placeholder-zinc-600 rounded-xl px-4 py-3 text-sm outline-none transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-rose-600 hover:bg-rose-500 disabled:opacity-60 disabled:cursor-not-allowed text-white font-bold py-4 rounded-xl transition-colors text-sm uppercase tracking-wider flex items-center justify-center gap-2"
          >
            <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span id="submit-label">Enviar Mensaje</span>
          </button>

          <p class="text-zinc-600 text-xs text-center">
            También puedes contactarnos por WhatsApp para una respuesta más rápida.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitLabel = document.getElementById('submit-label');
  const submitSpinner = document.getElementById('submit-spinner');
  const resetBtn = document.getElementById('form-reset');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl?.classList.add('hidden');

    // Loading state
    submitBtn.disabled = true;
    submitSpinner?.classList.remove('hidden');
    if (submitLabel) submitLabel.textContent = 'Enviando...';

    const data = new FormData(form);
    const json = Object.fromEntries(data.entries());

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(json),
      });

      const result = await res.json();

      if (result.success) {
        form.classList.add('hidden');
        successEl?.classList.remove('hidden');
        successEl?.classList.add('flex');
      } else {
        throw new Error(result.message || 'Error');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitSpinner?.classList.add('hidden');
      if (submitLabel) submitLabel.textContent = 'Enviar Mensaje';
    }
  });

  resetBtn?.addEventListener('click', () => {
    form.reset();
    form.classList.remove('hidden');
    successEl?.classList.add('hidden');
    successEl?.classList.remove('flex');
  });
</script>
