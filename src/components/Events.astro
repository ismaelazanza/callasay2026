---
const services = [
  {
    icon: '🔊',
    title: 'Sonido Profesional',
    desc: 'Equipos de sonido de alta calidad para eventos de cualquier escala.',
  },
  {
    icon: '🎛️',
    title: 'DJ & Mezcla',
    desc: 'DJs profesionales con años de experiencia animando eventos latinos.',
  },
  {
    icon: '💡',
    title: 'Iluminación',
    desc: 'Efectos de luces LED modernos que crean la atmósfera perfecta.',
  },
  {
    icon: '🎤',
    title: 'Artistas en Vivo',
    desc: 'Presentaciones de artistas ecuatorianos y latinoamericanos.',
  },
  {
    icon: '🎬',
    title: 'Pantallas & Video',
    desc: 'Pantallas de proyección gigantes para transmisiones y presentaciones.',
  },
  {
    icon: '🏟️',
    title: 'Tarimas & Escenarios',
    desc: 'Montaje de escenarios profesionales para conciertos y espectáculos.',
  },
];
---

<section id="eventos" class="relative py-24 bg-zinc-900/50">

  <!-- Section divider top -->
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Content -->
      <div>
        <div class="inline-flex items-center gap-2 bg-amber-950/40 border border-amber-900/40 rounded-full px-4 py-2 mb-6">
          <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
          </svg>
          <span class="text-amber-400 text-sm font-semibold uppercase tracking-wider">Scorpion Eventos</span>
        </div>

        <h2 class="text-4xl sm:text-5xl font-black text-white mb-6 leading-tight" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
          Producción de <span style="background: linear-gradient(135deg, #f59e0b, #ef4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Eventos</span>
          <br />a Tu Medida
        </h2>

        <p class="text-zinc-400 text-lg leading-relaxed mb-8">
          Organizamos eventos inolvidables para la comunidad ecuatoriana. Desde fiestas privadas hasta
          conciertos con artistas internacionales — nosotros lo hacemos posible.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a
            href="https://wa.me/12152077510"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-400 text-zinc-900 font-bold px-8 py-4 rounded-full transition-colors text-sm uppercase tracking-wider"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Cotizar Evento
          </a>
          <a
            href="tel:+12152077510"
            class="flex items-center justify-center gap-2 border border-zinc-700 hover:border-zinc-500 text-zinc-300 hover:text-white font-semibold px-8 py-4 rounded-full transition-colors text-sm"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            215-207-7510
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-6 text-center">
          <div>
            <div class="text-2xl font-black text-amber-400" style="font-family: 'Oswald', sans-serif;">500+</div>
            <div class="text-zinc-500 text-xs mt-1">Eventos realizados</div>
          </div>
          <div class="border-l border-zinc-800 pl-6">
            <div class="text-2xl font-black text-amber-400" style="font-family: 'Oswald', sans-serif;">10+</div>
            <div class="text-zinc-500 text-xs mt-1">Años de experiencia</div>
          </div>
          <div class="border-l border-zinc-800 pl-6">
            <div class="text-2xl font-black text-amber-400" style="font-family: 'Oswald', sans-serif;">2</div>
            <div class="text-zinc-500 text-xs mt-1">Países</div>
          </div>
        </div>
      </div>

      <!-- Right: Services grid -->
      <div class="grid grid-cols-2 gap-4">
        {services.map((service) => (
          <div class="bg-zinc-900 border border-zinc-800 hover:border-amber-800/50 rounded-2xl p-5 card-hover group">
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-white font-bold text-sm mb-2 group-hover:text-amber-400 transition-colors" style="font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: 0.05em;">
              {service.title}
            </h3>
            <p class="text-zinc-500 text-xs leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Section divider bottom -->
  <div class="section-divider absolute bottom-0 left-0 right-0"></div>
</section>
