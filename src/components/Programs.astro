---
const programs = [
  {
    name: 'Conexión Positiva',
    host: 'Jorguito Pintado',
    time: '5:00 AM – 8:00 AM',
    days: 'Lunes a Viernes',
    description: 'Un espacio dedicado a la música ecuatoriana de todos los tiempos. Pasillos, tecnocumbia, cumbia y éxitos del recuerdo para mantener vivas nuestras raíces.',
    color: 'from-amber-600 to-orange-700',
    icon: '🌅',
    tag: 'Matutino',
  },
  {
    name: 'Ritmo Total',
    host: 'Dj Charly',
    time: '8:00 AM – 12:00 PM',
    days: 'Lunes a Viernes',
    description: 'Un programa para la comunidad ecuatoriana en Estados Unidos con noticias, música, saludos de oyentes y temas de interés para quienes están lejos de casa.',
    color: 'from-rose-600 to-pink-700',
    icon: '🎵',
    tag: 'Música',
  },
  {
    name: 'Vaciando Botellas',
    host: 'Fernando y Aldo',
    time: '4:00 PM – 8:00 PM',
    days: 'Lunes a Viernes',
    description: 'Los mejores éxitos latinos para acompañarte en tu jornada. Salsa, merengue, bachata y música tropical con la energía de DJ Alex.',
    color: 'from-violet-600 to-purple-700',
    icon: '⚡',
    tag: 'Tarde',
  },
  {
    name: 'Un Gancho al Corazón',
    host: 'Diego Angamarca',
    time: '8:00 PM – 11:00 PM',
    days: 'Lunes a Viernes',
    description: 'Un viaje musical al pasado con canciones que marcaron generaciones. Ideal para recordar momentos especiales y revivir la nostalgia de nuestra tierra.',
    color: 'from-blue-600 to-cyan-700',
    icon: '🌙',
    tag: 'Nocturno',
  },
  {
    name: 'La Hora del Migrante',
    host: 'Daniela Paredes',
    time: '10:00 AM – 2:00 PM',
    days: 'Sábados y Domingos',
    description: 'Un espacio dedicado a los ecuatorianos que viven en el exterior, con historias, mensajes de oyentes y música que une a nuestra comunidad.',
    color: 'from-emerald-600 to-teal-700',
    icon: '🎉',
    tag: 'Fin de Semana',
  },
  {
    name: 'Música Rokolera',
    host: 'Dj Tatu y dj Aldo Tapia',
    time: 'Horario especial',
    days: 'Programación variable',
    description: 'Un programa lleno de ritmo y alegría con tecnocumbia, cumbia y música bailable para poner a todos a disfrutar sin importar la distancia.',
    color: 'from-red-600 to-rose-700',
    icon: '🎤',
    tag: 'Especial',
  },
];
---

<section id="programas" class="relative py-24 bg-zinc-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-rose-950/40 border border-rose-900/40 rounded-full px-4 py-2 mb-4">
        <svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-rose-400 text-sm font-semibold uppercase tracking-wider">Programación</span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-black text-white mb-4" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
        Nuestros <span class="gradient-text">Programas</span>
      </h2>
      <p class="text-zinc-400 text-lg max-w-2xl mx-auto">
        Transmitimos música nacional, éxitos del recuerdo y programación variada con DJ y locutores en vivo que te acompañan las 24 horas.
      </p>
    </div>

    <!-- Programs grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {programs.map((program, index) => (
        <div
          class="group bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden card-hover cursor-pointer"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Card header -->
          <div class={`bg-gradient-to-r ${program.color} p-6 relative overflow-hidden`}>
            <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 20px 20px;"></div>
            <div class="relative z-10 flex items-start justify-between">
              <div>
                <span class="text-white/80 text-xs font-semibold uppercase tracking-widest bg-black/20 rounded-full px-3 py-1">
                  {program.tag}
                </span>
                <div class="text-4xl mt-3">{program.icon}</div>
              </div>
              <div class="text-right">
                <div class="text-white font-bold text-lg leading-tight" style="font-family: 'Oswald', sans-serif;">
                  {program.time}
                </div>
                <div class="text-white/70 text-xs mt-1">{program.days}</div>
              </div>
            </div>
          </div>

          <!-- Card body -->
          <div class="p-6">
            <h3 class="text-white font-bold text-xl mb-1" style="font-family: 'Oswald', sans-serif; text-transform: uppercase; letter-spacing: 0.03em;">
              {program.name}
            </h3>
            <p class="text-rose-400 text-sm font-medium mb-3">con {program.host}</p>
            <p class="text-zinc-400 text-sm leading-relaxed">{program.description}</p>

            <div class="mt-4 pt-4 border-t border-zinc-800 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="live-dot w-2 h-2 rounded-full bg-rose-500"></span>
                <span class="text-zinc-500 text-xs">EN VIVO</span>
              </div>
              <button class="text-rose-400 hover:text-rose-300 text-sm font-semibold flex items-center gap-1 transition-colors group-hover:gap-2">
                Escuchar
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Schedule CTA -->
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-3 bg-zinc-900 border border-zinc-800 rounded-2xl px-8 py-6">
        <svg class="w-6 h-6 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div class="text-left">
          <p class="text-white font-semibold">Transmisión 24/7</p>
          <p class="text-zinc-500 text-sm">Siempre conectados con la comunidad ecuatoriana</p>
        </div>
        <a
          href="https://wa.link/6y7dlp"
          target="_blank"
          rel="noopener"
          class="bg-rose-600 hover:bg-rose-500 text-white text-sm font-bold px-5 py-2.5 rounded-xl transition-colors ml-4"
        >
          Contáctanos
        </a>
      </div>
    </div>
  </div>
</section>
