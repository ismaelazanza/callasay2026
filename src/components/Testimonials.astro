---
const testimonials = [
  {
    name: 'María González',
    location: 'Brooklyn, New York',
    message: 'Saludos desde New York. Gracias por mantener viva nuestra música ecuatoriana. Escucharlos es como estar en casa.',
    initials: 'MG',
    color: 'bg-rose-700',
  },
  {
    name: 'Carlos Ávila',
    location: 'Newark, New Jersey',
    message: 'Excelente programación. Me acompañan todos los días en el trabajo. ¡Sigan adelante con esta gran radio!',
    initials: 'CA',
    color: 'bg-violet-700',
  },
  {
    name: 'Rosa Ortega',
    location: 'Philadelphia, PA',
    message: 'Un abrazo para todo el equipo. Qué alegría escuchar música de nuestro Ecuador estando lejos.',
    initials: 'RO',
    color: 'bg-amber-700',
  },
  {
    name: 'José Bermeo',
    location: 'Queens, New York',
    message: 'Los escucho desde New Jersey. Muy buenos DJ y locutores, siempre con buena energía.',
    initials: 'JB',
    color: 'bg-emerald-700',
  },
  {
    name: 'Patricia Sarmiento',
    location: 'Lima, Perú',
    message: 'Gracias por alegrar nuestras jornadas con tan buena música. ¡La mejor radio para los ecuatorianos en Estados Unidos!',
    initials: 'PS',
    color: 'bg-blue-700',
  },
  {
    name: 'Luis Morocho',
    location: 'Bronx, New York',
    message: 'Felicitaciones por esta radio. Nos hacen sentir más cerca de nuestra tierra.',
    initials: 'LM',
    color: 'bg-red-700',
  },
];
---

<section id="testimonios" class="relative py-24 bg-zinc-950">
  
    <!-- Section divider top -->
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-rose-950/40 border border-rose-900/40 rounded-full px-4 py-2 mb-4">
        <svg class="w-4 h-4 text-rose-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <span class="text-rose-400 text-sm font-semibold uppercase tracking-wider">Nuestra Comunidad</span>
      </div>

      <h2 class="text-4xl sm:text-5xl font-black text-white mb-4" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
        Mensajes de <span class="gradient-text">Oyentes</span>
      </h2>
      <p class="text-zinc-400 text-lg max-w-2xl mx-auto">
        Sintoniza nuestra radio online y disfruta lo mejor de nuestra música y nuestra gente.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((t, index) => (
        <div
          class="bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-2xl p-6 card-hover"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-rose-800 mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.95.78-3 .53-.81 1.24-1.49 2.13-2.05L9.19 6c-.28.19-.59.42-.93.69-.34.27-.67.6-1 1-.33.39-.6.83-.8 1.32-.22.5-.33 1.05-.33 1.66 0 1.22.44 2.24 1.33 3.06.89.82 1.96 1.23 3.22 1.23v1.78zm8 0c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.95.78-3 .53-.81 1.24-1.49 2.13-2.05L17.19 6c-.28.19-.59.42-.93.69-.34.27-.67.6-1 1-.33.39-.6.83-.8 1.32-.22.5-.33 1.05-.33 1.66 0 1.22.44 2.24 1.33 3.06.89.82 1.96 1.23 3.22 1.23v1.78z"/>
          </svg>

          <p class="text-zinc-300 text-sm leading-relaxed mb-6 italic">"{t.message}"</p>

          <div class="flex items-center gap-3 pt-4 border-t border-zinc-800">
            <div class={`w-10 h-10 rounded-full ${t.color} flex items-center justify-center text-white font-bold text-sm flex-shrink-0`}>
              {t.initials}
            </div>
            <div>
              <div class="text-white font-semibold text-sm">{t.name}</div>
              <div class="text-zinc-500 text-xs flex items-center gap-1">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                </svg>
                {t.location}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Send message CTA -->
    <div class="mt-16 bg-gradient-to-r from-rose-950/40 to-zinc-900/40 border border-rose-900/30 rounded-3xl p-8 sm:p-12 text-center">
      <h3 class="text-2xl sm:text-3xl font-black text-white mb-4" style="font-family: 'Oswald', sans-serif; text-transform: uppercase;">
        Envía tu Saludo
      </h3>
      <p class="text-zinc-400 mb-8 max-w-xl mx-auto">
        ¿Quieres mandar un saludo a tu familia o dedicar una canción? Escríbenos por WhatsApp o llámanos.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://wa.link/6y7dlp"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white font-bold px-8 py-4 rounded-full transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Enviar Saludo por WhatsApp
        </a>
        <a
          href="tel:+7738070486"
          class="flex items-center gap-2 border border-zinc-700 hover:border-zinc-500 text-zinc-300 hover:text-white font-semibold px-8 py-4 rounded-full transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Llamar: 773-807-0486
        </a>
      </div>
    </div>
  </div>
</section>
